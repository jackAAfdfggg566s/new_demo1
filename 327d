七、给你一个完整脚本（推荐直接用）
Python
import requests

GITLAB_URL = "https://gitlab.com/api/v4"
PROJECT_ID = "123456"
TOKEN = "xxxx"

def run_pipeline(duration):

    url = f"{GITLAB_URL}/projects/{PROJECT_ID}/pipeline"

    payload = {
        "ref": "main",
        "variables": [
            {"key": "TEST_DURATION", "value": str(duration)}
        ]
    }

    headers = {"PRIVATE-TOKEN": TOKEN}

    r = requests.post(url, headers=headers, json=payload)

    pipeline = r.json()

    print("Pipeline URL:", pipeline["web_url"])

    return pipeline["id"]

run_pipeline(5)
