Step 3：完整 .gitlab-ci.yml
这里不是空的。
stages:
  - generate
  - trigger

generate-monitor:
  stage: generate

  script:
    - chmod +x generate_monitor_yaml.sh
    - ./generate_monitor_yaml.sh

  artifacts:
    paths:
      - monitor-pipeline.yml

trigger-monitor:
  stage: trigger

  trigger:
    include:
      - artifact: monitor-pipeline.yml
        job: generate-monitor

    strategy: depend
