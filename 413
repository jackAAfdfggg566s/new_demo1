HTML
<!-- index.html -->
<!DOCTYPE html>
<html>
<head>
    <title>Remote Control</title>
</head>
<body>

<h2>Update Config</h2>
<input id="key" placeholder="key">
<input id="value" placeholder="value">
<button onclick="updateConfig()">Update</button>

<h2>Run Script</h2>
<button onclick="runScript()">Run</button>

<pre id="output"></pre>

<script>
const SERVER = "http://<机器B_IP>:5000";

function updateConfig() {
    const key = document.getElementById("key").value;
    const value = document.getElementById("value").value;

    fetch(SERVER + "/update_config", {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({key, value})
    })
    .then(r => r.json())
    .then(d => alert(JSON.stringify(d)));
}

function runScript() {
    fetch(SERVER + "/run_script", {method: "POST"})
    .then(r => r.json())
    .then(d => {
        document.getElementById("output").innerText =
            "STDOUT:\n" + d.stdout + "\n\nSTDERR:\n" + d.stderr;
    });
}
</script>

</body>
</html>
