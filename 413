# server.py
from flask import Flask, request, jsonify
import subprocess
import os

app = Flask(__name__)

CONFIG_PATH = "/home/user/config.cfg"
SCRIPT_PATH = "/home/user/run.sh"

@app.route("/update_config", methods=["POST"])
def update_config():
    data = request.json
    key = data.get("key")
    value = data.get("value")

    if not key:
        return jsonify({"error": "key required"}), 400

    update_config_file(CONFIG_PATH, key, value)

    return jsonify({"status": "config updated"})


@app.route("/run_script", methods=["POST"])
def run_script():
    try:
        result = subprocess.run(
            ["bash", SCRIPT_PATH],
            capture_output=True,
            text=True
        )

        return jsonify({
            "stdout": result.stdout,
            "stderr": result.stderr,
            "returncode": result.returncode
        })
    except Exception as e:
        return jsonify({"error": str(e)}), 500


def update_config_file(path, key, value):
    lines = []

    if os.path.exists(path):
        with open(path, "r") as f:
            lines = f.readlines()

    updated = False
    new_lines = []

    for line in lines:
        if line.strip().startswith(f"{key}="):
            new_lines.append(f"{key}={value}\n")
            updated = True
        else:
            new_lines.append(line)

    if not updated:
        new_lines.append(f"{key}={value}\n")

    with open(path, "w") as f:
        f.writelines(new_lines)


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
✅ 2.2 本地/网页端调用 API（Python client）
Python
# client.py
import requests

SERVER = "http://<机器B_IP>:5000"

def update_config(key, value):
    r = requests.post(
        f"{SERVER}/update_config",
        json={"key": key, "value": value}
    )
    print(r.json())


def run_script():
    r = requests.post(f"{SERVER}/run_script")
    print("STDOUT:\n", r.json().get("stdout"))
    print("STDERR:\n", r.json().get("stderr"))


if __name__ == "__main__":
    update_config("env", "prod")
    run_script()
