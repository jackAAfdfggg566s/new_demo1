✅ 方案1：Playwright 登录态复用（完整代码）
🔹 第一步：手动登录一次，保存 session
# save_login_state.py
from playwright.sync_api import sync_playwright

GITLAB_URL = "https://gitlab.com"

with sync_playwright() as p:
    browser = p.chromium.launch(headless=False)  # 必须False，手动登录
    context = browser.new_context()

    page = context.new_page()
    page.goto(f"{GITLAB_URL}/users/sign_in")

    input("👉 请在浏览器完成登录（SSO/MFA），完成后按回车...")

    # 保存登录态
    context.storage_state(path="state.json")

    print("✅ 登录状态已保存到 state.json")

    browser.close()
🔹 第二步：用登录态截图
# screenshot_gitlab.py
from playwright.sync_api import sync_playwright

PIPELINE_URL = "https://gitlab.com/你的项目/-/pipelines"

with sync_playwright() as p:
    browser = p.chromium.launch(headless=True)

    # 加载登录态
    context = browser.new_context(storage_state="state.json")
    page = context.new_page()

    page.goto(PIPELINE_URL)

    # 等待页面加载
    page.wait_for_timeout(5000)

    page.screenshot(path="pipeline.png", full_page=True)

    print("✅ 截图完成 pipeline.png")

    browser.close()
✅ 方案2：日志文件 → 图片（推荐，最稳）
🔹 方法2.1：Python 转图片（完整可用）
# log_to_image.py
from PIL import Image, ImageDraw, ImageFont

LOG_FILE = "test.log"
OUTPUT_IMG = "output.png"

# 读取日志
with open(LOG_FILE, "r", encoding="utf-8") as f:
    lines = f.readlines()

# 图片参数
font_size = 16
line_height = font_size + 4
img_width = 1200
img_height = line_height * len(lines) + 20

# 创建图片
img = Image.new("RGB", (img_width, img_height), color="black")
draw = ImageDraw.Draw(img)

# 字体（Linux 可用默认）
try:
    font = ImageFont.truetype("DejaVuSansMono.ttf", font_size)
except:
    font = ImageFont.load_default()

# 写入文字
y = 10
for line in lines:
    draw.text((10, y), line.strip(), fill="white", font=font)
    y += line_height

# 保存
img.save(OUTPUT_IMG)

print(f"✅ 已生成图片: {OUTPUT_IMG}")
