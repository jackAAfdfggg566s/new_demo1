import glob
import os
from docx import Document
from docx.shared import Inches

# 🔧 变量（匹配规则）
keyword = "pt_test"   # 👈 对应 shell 的 *pt_test*

# 🔧 图片目录
image_dir = "./images"

# 🔧 匹配图片（等价于：ls *pt_test*.png）
pattern = os.path.join(image_dir, f"*{keyword}*.png")
image_files = sorted(glob.glob(pattern))

# 创建 Word
doc = Document()
doc.add_heading(f"Report - {keyword}", 1)

if not image_files:
    doc.add_paragraph("No images found.")
else:
    for i, img in enumerate(image_files, 1):
        filename = os.path.basename(img)

        # 添加标题
        doc.add_paragraph(f"Figure {i}: {filename}")

        # 插入图片
        doc.add_picture(img, width=Inches(5))

# 保存
doc.save(f"{keyword}_report.docx")
