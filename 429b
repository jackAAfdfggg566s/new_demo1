import os
from playwright.sync_api import sync_playwright
from config import BASE_DIR, BASE_URL, SCREENSHOT_DIR


def build_url(subdir, filename):
    dir_path = os.path.join(BASE_DIR, subdir)
    file_path = os.path.join(dir_path, filename)

    # 校验目录
    if not os.path.isdir(dir_path):
        return None, f"dir not exist: {dir_path}"

    # 校验文件
    if not os.path.exists(file_path):
        return None, f"file not exist: {file_path}"

    url = f"{BASE_URL}/{subdir}/{filename}"
    return url, None


def capture_one(subdir, filename):
    os.makedirs(SCREENSHOT_DIR, exist_ok=True)

    url, err = build_url(subdir, filename)
    if err:
        return {
            "status": "fail",
            "error": err
        }

    file_path = os.path.join(SCREENSHOT_DIR, f"{subdir}.png")

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=True)
        context = browser.new_context(viewport={"width": 1280, "height": 2000})
        page = context.new_page()

        try:
            print(f"[INFO] {url}")
            page.goto(url, timeout=60000, wait_until="networkidle")
            page.screenshot(path=file_path, full_page=True)

            result = {
                "status": "success",
                "dir": subdir,
                "url": url,
                "file": file_path
            }

        except Exception as e:
            result = {
                "status": "fail",
                "dir": subdir,
                "url": url,
                "error": str(e)
            }

        browser.close()

    return result
✅ 四、app.py（Flask）
Python
from flask import Flask, send_from_directory, request, jsonify
from config import BASE_DIR
from capture import capture_one

app = Flask(__name__)


# 👉 提供静态访问
@app.route('/logs/<path:filepath>')
def serve_logs(filepath):
    return send_from_directory(BASE_DIR, filepath)


# 👉 截图接口（只处理一个目录）
@app.route('/capture', methods=['GET'])
def capture():
    subdir = request.args.get("dir")
    filename = request.args.get("file")

    if not subdir or not filename:
        return jsonify({
            "error": "dir and file required"
        }), 400

    result = capture_one(subdir, filename)

    return jsonify(result)


if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
