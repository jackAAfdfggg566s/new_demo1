✅ 三、capture.py（核心逻辑）
Python
import os
from playwright.sync_api import sync_playwright
from config import BASE_DIR, BASE_URL, SCREENSHOT_DIR


def find_dirs(keyword):
    matched = []
    for name in os.listdir(BASE_DIR):
        full_path = os.path.join(BASE_DIR, name)
        if os.path.isdir(full_path) and keyword in name:
            matched.append(name)
    return matched


def build_urls(keyword):
    dirs = find_dirs(keyword)
    urls = []
    for d in dirs:
        url = f"{BASE_URL}/{d}/index.html"
        urls.append((d, url))
    return urls


def screenshot_urls(urls):
    os.makedirs(SCREENSHOT_DIR, exist_ok=True)

    results = []

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=True)

        # 如果有登录问题，用这个
        context = browser.new_context(
            viewport={"width": 1280, "height": 2000}
        )
        page = context.new_page()

        for name, url in urls:
            file_path = os.path.join(SCREENSHOT_DIR, f"{name}.png")
            print(f"[INFO] capturing: {url}")

            try:
                page.goto(url, timeout=60000, wait_until="networkidle")
                page.screenshot(path=file_path, full_page=True)

                results.append({
                    "name": name,
                    "url": url,
                    "file": file_path,
                    "status": "success"
                })

            except Exception as e:
                results.append({
                    "name": name,
                    "url": url,
                    "error": str(e),
                    "status": "fail"
                })

        browser.close()

    return results


def run_capture(keyword):
    urls = build_urls(keyword)

    if not urls:
        return {
            "count": 0,
            "message": "no matched dirs",
            "results": []
        }

    results = screenshot_urls(urls)

    return {
        "count": len(results),
        "results": results
    }
✅ 四、app.py（Flask入口）
Python
from flask import Flask, send_from_directory, request, jsonify
import os
from config import BASE_DIR
from capture import run_capture

app = Flask(__name__)


# 👉 提供静态文件访问
@app.route('/logs/<path:filepath>')
def serve_logs(filepath):
    return send_from_directory(BASE_DIR, filepath)


# 👉 截图接口
@app.route('/capture', methods=['GET'])
def capture():
    keyword = request.args.get("keyword")

    if not keyword:
        return jsonify({"error": "keyword required"}), 400

    result = run_capture(keyword)

    return jsonify(result)


if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
