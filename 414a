from flask import Flask, jsonify, send_file
import subprocess
import os
from playwright.sync_api import sync_playwright
import time

app = Flask(__name__)

# 配置
REMOTE_HOST = "user@machine_b"
REMOTE_HTML = "/tmp/result.html"
LOCAL_HTML = "temp/result.html"
SCREENSHOT_PATH = "screenshot/result.png"

SQL = """
SELECT * FROM your_table LIMIT 20;
"""

def run_remote_sql():
    """在B执行SQL并生成HTML"""
    cmd = f"""
    ssh {REMOTE_HOST} '
    mysql -uuser -ppassword -e "{SQL}" --html > {REMOTE_HTML}
    '
    """
    subprocess.run(cmd, shell=True, check=True)

def fetch_html():
    """从B拉HTML到A"""
    cmd = f"scp {REMOTE_HOST}:{REMOTE_HTML} {LOCAL_HTML}"
    subprocess.run(cmd, shell=True, check=True)

def take_screenshot():
    """Playwright截图"""
    with sync_playwright() as p:
        browser = p.chromium.launch()
        page = browser.new_page()

        file_path = "file://" + os.path.abspath(LOCAL_HTML)
        page.goto(file_path)

        # 等待页面加载
        time.sleep(1)

        page.screenshot(path=SCREENSHOT_PATH, full_page=True)
        browser.close()

@app.route("/run_and_capture", methods=["GET"])
def run_and_capture():
    try:
        # 1. 远端执行SQL
        run_remote_sql()

        # 2. 拉HTML
        fetch_html()

        # 3. 截图
        take_screenshot()

        return send_file(SCREENSHOT_PATH, mimetype='image/png')

    except Exception as e:
        return jsonify({"error": str(e)}), 500


if __name__ == "__main__":
    os.makedirs("temp", exist_ok=True)
    os.makedirs("screenshot", exist_ok=True)
    app.run(host="0.0.0.0", port=5000)
