⚙️ 四、GitLab Pipeline 示例
✅ .gitlab-ci.yml
YAML
image: python:3.10

stages:
  - screenshot

before_script:
  - pip install playwright
  - playwright install chromium

  # 写入 session 文件
  - echo "$AWS_STATE_JSON" > aws_state.json

screenshot:
  stage: screenshot
  script:
    - python aws_screenshot.py \
        "https://ap-southeast-2.console.aws.amazon.com/cloudwatch/home#dashboards:name=your-dashboard" \
        "aws.png"

    - ls -l aws.png

  artifacts:
    paths:
      - aws.png
