🧩 一、初始化脚本（只做一次）
👉 在你本地机器运行（必须能打开浏览器）
✅ save_session.py
Python
from playwright.sync_api import sync_playwright

STATE_FILE = "aws_state.json"

with sync_playwright() as p:
    browser = p.chromium.launch(headless=False)  # 必须 False
    context = browser.new_context()

    page = context.new_page()

    # 打开 AWS Access Portal / Console
    page.goto("https://console.aws.amazon.com/")

    print("👉 请在浏览器中完成 AWS SSO 登录（包括 MFA）")
    input("👉 登录完成后按回车继续...")

    # 保存 session
    context.storage_state(path=STATE_FILE)

    browser.close()

print(f"✅ Session 已保存到 {STATE_FILE}")
