好，这里给你一个完整可跑的“方案2（截关键字上下文）”代码，从加载日志 → 定位关键字 → 截上下文区域，一步到位。
使用 Playwright
✅ ✅ 完整 Python 代码（上下文截图版）
Python
from playwright.sync_api import sync_playwright

URL = "http://your-log-page"   # 可以是 http://... 或 file:///...
KEYWORD = "ERROR"
OUTPUT = "context.png"

# 上下扩展像素（可调）
TOP_PADDING = 200
BOTTOM_PADDING = 200

with sync_playwright() as p:
    browser = p.chromium.launch(headless=True)
    page = browser.new_page()

    # 打开页面
    page.goto(URL)

    # 等页面加载（可根据情况调整）
    page.wait_for_load_state("networkidle")

    # 查找关键字
    locator = page.locator(f"text={KEYWORD}")

    if locator.count() == 0:
        print(f"❌ Keyword '{KEYWORD}' not found")
        browser.close()
        exit(1)

    # 取第一个匹配
    element = locator.first

    # 滚动到元素
    element.scroll_into_view_if_needed()

    # 获取元素位置
    box = element.bounding_box()

    if not box:
        print("❌ Cannot get element position")
        browser.close()
        exit(1)

    # 获取页面高度（防止越界）
    page_height = page.evaluate("document.body.scrollHeight")

    # 计算截图区域（上下扩展）
    clip_y = max(0, box["y"] - TOP_PADDING)
    clip_height = min(
        page_height - clip_y,
        box["height"] + TOP_PADDING + BOTTOM_PADDING
    )

    clip = {
        "x": 0,   # 从最左开始（日志一般全宽）
        "y": clip_y,
        "width": page.viewport_size["width"],
        "height": clip_height
    }

    # 截图
    page.screenshot(path=OUTPUT, clip=clip)

    print(f"✅ Screenshot saved to {OUTPUT}")

    browser.close()
